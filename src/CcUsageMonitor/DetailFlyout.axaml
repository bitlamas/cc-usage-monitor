<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:CcUsageMonitor"
        x:Class="CcUsageMonitor.DetailFlyout"
        Title="Claude Code Usage"
        Width="300"
        SizeToContent="Height"
        MaxHeight="420"
        WindowStartupLocation="Manual"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ShowInTaskbar="False"
        Topmost="True">

  <Border Background="#1C1B19"
          CornerRadius="12"
          BorderBrush="#3A3833"
          BorderThickness="1"
          Padding="16,14">
    <StackPanel Spacing="13">

      <!-- Header -->
      <Grid ColumnDefinitions="Auto,*,Auto">
        <Border Grid.Column="0" Width="9" Height="9" CornerRadius="3"
                Background="#D97757" VerticalAlignment="Center" Margin="0,0,9,0"/>
        <TextBlock Grid.Column="1" Text="Claude Code usage"
                   FontSize="12.5" FontWeight="SemiBold" Foreground="#EDEAE3"
                   VerticalAlignment="Center"/>
        <TextBlock Grid.Column="2" x:Name="UpdatedText" Text=""
                   FontSize="11" Foreground="#857F75" VerticalAlignment="Center"/>
      </Grid>

      <!-- Limit rows -->
      <ItemsControl x:Name="LimitsList">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:FlyoutItem">
            <StackPanel Spacing="6" Margin="0,0,0,9">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Label}"
                           FontSize="13" FontWeight="Medium" Foreground="#EDEAE3"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding PctText}"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{Binding BandBrush}" VerticalAlignment="Center"/>
              </Grid>
              <Border Height="6" CornerRadius="3" Background="#2E2C28" ClipToBounds="True">
                <Border HorizontalAlignment="Left" Width="{Binding BarFillWidth}"
                        CornerRadius="3" Background="{Binding BandBrush}"/>
              </Border>
              <TextBlock Text="{Binding ResetText}" FontSize="11" Foreground="#857F75"/>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Stale indicator -->
      <TextBlock x:Name="StaleText" Text="" FontSize="11"
                 Foreground="#E0A92E" TextWrapping="Wrap" IsVisible="False"/>
    </StackPanel>
  </Border>
</Window>
